---
import Base from './Base.astro';
import { url } from '../lib/base';
import { formatDate } from '../lib/date';
import 'katex/dist/katex.min.css';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
const { post, headings, newer, older } = Astro.props;
const { title, date, minutes, youtube, thumbnail, excerpt } = post.data;

// Nested TOC: h2 sections with their h3 children.
const toc: (Heading & { children: Heading[] })[] = [];
for (const h of headings as Heading[]) {
  if (h.depth === 2) toc.push({ ...h, children: [] });
  else if (h.depth === 3 && toc.length) toc[toc.length - 1].children.push(h);
}
---

<Base title={`${title} — мыш блог`} description={excerpt} image={thumbnail} type="article">
  <div class="progress" data-progress></div>

  <article class="wrap">
    <a class="back mono" href={url()}>← Все посты</a>

    <header class="post-head">
      <div class="meta mono">
        <span class="hl">{formatDate(date)}</span>
        <span class="sep">·</span>
        <span>{minutes} мин</span>
      </div>
      <h1>{title}</h1>
    </header>

    <a class="cta" href={youtube} target="_blank" rel="noopener">
      <div class="cta-thumb"><img src={url(thumbnail)} alt="" /></div>
      <div class="cta-text">
        <span class="mono kicker">Оригинал · YouTube</span>
        <span class="cta-title">Смотреть видео-версию</span>
      </div>
      <div class="cta-play" aria-hidden="true">▶</div>
    </a>

    {
      toc.length > 0 && (
        <details class="toc-mobile">
          <summary class="mono">Содержание</summary>
          <nav>
            {toc.map((t) => (
              <>
                <a href={`#${t.slug}`}>{t.text}</a>
                {t.children.map((c) => (
                  <a class="sub" href={`#${c.slug}`}>
                    {c.text}
                  </a>
                ))}
              </>
            ))}
          </nav>
        </details>
      )
    }

    <div class="layout">
      <div class="col">
        <div class="prose"><slot /></div>

        <nav class="prevnext">
          {
            newer && (
              <a class="pn newer" href={url(`posts/${newer.id}/`)}>
                <span class="mono dir">↑ Новее</span>
                <span class="pn-title">{newer.data.title}</span>
              </a>
            )
          }
          {
            older && (
              <a class="pn older" href={url(`posts/${older.id}/`)}>
                <span class="mono dir">Старше ↓</span>
                <span class="pn-title">{older.data.title}</span>
              </a>
            )
          }
        </nav>
      </div>

      {
        toc.length > 0 && (
          <aside class="toc">
            <div class="mono toc-title">Содержание</div>
            <nav>
              {toc.map((t) => (
                <>
                  <a class="toc-link" href={`#${t.slug}`} data-toc-link={t.slug}>
                    {t.text}
                  </a>
                  {t.children.map((c) => (
                    <a class="toc-link sub" href={`#${c.slug}`} data-toc-link={c.slug}>
                      {c.text}
                    </a>
                  ))}
                </>
              ))}
            </nav>
            <a class="toc-video mono" href={youtube} target="_blank" rel="noopener">
              ▶ Видео-версия
            </a>
          </aside>
        )
      }
    </div>
  </article>
</Base>

<script>
  // Scroll-progress bar + TOC scrollspy. Anchor scrolling itself is native
  // (scroll-behavior: smooth + scroll-margin-top on headings).
  const bar = document.querySelector<HTMLElement>('[data-progress]');
  const links = [...document.querySelectorAll<HTMLElement>('[data-toc-link]')];
  const targets = links
    .map((l) => document.getElementById(l.dataset.tocLink!))
    .filter((el): el is HTMLElement => !!el);

  let ticking = false;
  function update() {
    ticking = false;
    const doc = document.documentElement;
    const max = doc.scrollHeight - doc.clientHeight;
    const pct = max > 0 ? Math.min(100, Math.max(0, (window.scrollY / max) * 100)) : 0;
    if (bar) bar.style.width = pct + '%';

    let active = targets[0];
    for (const t of targets) if (t.getBoundingClientRect().top <= 120) active = t;
    for (const l of links) l.classList.toggle('active', !!active && l.dataset.tocLink === active.id);
  }
  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(update);
  }
  addEventListener('scroll', onScroll, { passive: true });
  addEventListener('resize', onScroll, { passive: true });
  update();
</script>

<style>
  .progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    z-index: 70;
    transition: width 0.08s linear;
  }

  .wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 22px 120px;
  }

  .back {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin-top: 30px;
    font-size: 12px;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .back:hover {
    color: #fff;
  }

  .post-head {
    padding: 26px 0 30px;
    border-bottom: 1px solid var(--line);
  }
  .meta {
    display: flex;
    gap: 12px;
    font-size: 12px;
    color: var(--fg-dim);
  }
  .meta .hl {
    color: #fff;
  }
  .meta .sep {
    color: rgba(255, 255, 255, 0.3);
  }
  .post-head h1 {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(34px, 5vw, 58px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: #fff;
    text-wrap: balance;
  }

  /* YouTube CTA */
  .cta {
    display: flex;
    align-items: stretch;
    margin: 30px 0 8px;
    border: 1px solid #fff;
    color: #fff;
    text-decoration: none;
    transition: background 0.2s;
  }
  .cta:hover {
    background: rgba(255, 255, 255, 0.08);
  }
  .cta-thumb {
    position: relative;
    width: 148px;
    flex: none;
    overflow: hidden;
    border-right: 1px solid currentColor;
    background: #0a0a0a;
  }
  .cta-thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.05);
  }
  .cta-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 8px;
    padding: 20px 22px;
  }
  .cta .kicker {
    font-size: 11px;
    letter-spacing: 0.16em;
    opacity: 0.55;
  }
  .cta-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(22px, 3.2vw, 27px);
    line-height: 1.06;
    letter-spacing: -0.01em;
  }
  .cta-play {
    flex: none;
    width: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid currentColor;
    font-size: 18px;
  }

  /* layout */
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 232px;
    gap: 54px;
    align-items: start;
    margin-top: 36px;
  }
  .col {
    max-width: 740px;
    min-width: 0;
  }

  /* prev / next */
  .prevnext {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-top: 54px;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  .pn {
    padding: 18px;
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    text-decoration: none;
    color: #fff;
    transition: background 0.15s;
  }
  .pn:hover {
    background: var(--hover);
  }
  .pn.older {
    grid-column: 2;
    text-align: right;
  }
  .pn .dir {
    display: block;
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--fg-faint);
    margin-bottom: 8px;
  }
  .pn-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    line-height: 1.18;
  }

  /* sticky TOC */
  .toc {
    position: sticky;
    top: 90px;
    align-self: start;
  }
  .toc-title {
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--fg-faint);
    padding-bottom: 14px;
    margin-bottom: 6px;
    border-bottom: 1px solid var(--line);
  }
  .toc nav {
    display: flex;
    flex-direction: column;
  }
  .toc-link {
    border-left: 2px solid transparent;
    padding: 7px 0 7px 13px;
    font-size: 14px;
    line-height: 1.35;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s;
  }
  .toc-link.sub {
    padding: 6px 0 6px 26px;
    font-size: 13px;
  }
  .toc-link:hover {
    color: #fff;
  }
  .toc-link.active {
    color: #fff;
    border-left-color: var(--accent);
    font-weight: 600;
  }
  .toc-video {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--fg-dim);
    text-decoration: none;
    transition: color 0.15s;
  }
  .toc-video:hover {
    color: #fff;
  }

  .toc-mobile {
    display: none;
    margin: 26px 0 4px;
    border: 1px solid var(--line);
  }
  .toc-mobile summary {
    padding: 15px 16px;
    font-size: 12px;
    letter-spacing: 0.16em;
    color: #fff;
    cursor: pointer;
    list-style: none;
  }
  .toc-mobile nav {
    display: flex;
    flex-direction: column;
    padding: 4px 0 10px;
    border-top: 1px solid var(--line);
  }
  .toc-mobile a {
    padding: 10px 16px;
    font-size: 15px;
    color: var(--fg-dim);
    text-decoration: none;
  }
  .toc-mobile a.sub {
    padding-left: 32px;
    font-size: 14px;
  }

  @media (max-width: 820px) {
    .layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 0;
    }
    .toc {
      display: none;
    }
    .toc-mobile {
      display: block;
    }
    .cta-thumb {
      display: none;
    }
  }

  /* ---------- prose (markdown-rendered content) ---------- */
  .prose :global(p) {
    margin: 0 0 22px;
    font-size: 18px;
    line-height: 1.72;
    color: var(--fg-body);
    text-wrap: pretty;
  }
  .prose :global(h2) {
    margin: 52px 0 22px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 30px;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
    scroll-margin-top: 90px;
  }
  .prose :global(h3) {
    margin: 38px 0 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.92);
    scroll-margin-top: 90px;
  }
  .prose :global(a) {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--line-strong);
  }
  .prose :global(a:hover) {
    text-decoration-color: #fff;
  }
  .prose :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    padding: 2px 6px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.04);
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 24px;
    font-size: 15px;
    line-height: 1.5;
  }
  .prose :global(th),
  .prose :global(td) {
    border: 1px solid var(--line);
    padding: 9px 12px;
    text-align: left;
    vertical-align: top;
  }
  .prose :global(th) {
    font-weight: 700;
    color: #fff;
    background: rgba(255, 255, 255, 0.03);
  }
  .prose :global(td) {
    color: var(--fg-body);
  }
  .prose :global(td code) {
    white-space: nowrap;
  }
  /* :not([class]) targets our rehype-figures images only — Expressive Code's
     own <figure class="frame"> / <figcaption class="header"> are left to EC. */
  .prose :global(figure:not([class])) {
    margin: 0 0 26px;
    border: 1px solid var(--line);
  }
  .prose :global(figure:not([class]) img) {
    width: 100%;
    background: #000;
  }
  .prose :global(figure:not([class]) > figcaption) {
    padding: 11px 14px;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    line-height: 1.5;
    color: var(--fg-dim);
  }
  .prose :global(.expressive-code) {
    margin: 0 0 24px;
  }
  /* program-output blocks: dimmer, joined to the code above */
  .prose :global(.expressive-code.is-output) {
    margin-top: -14px;
    opacity: 0.72;
  }
  .prose :global(.katex-display) {
    margin: 24px 0;
    overflow-x: auto;
    overflow-y: hidden;
  }
</style>
